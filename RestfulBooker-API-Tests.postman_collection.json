  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "TC01-Auth-Valid-Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Check status code is 200\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Test 2: Check response has token property\r",
                  "pm.test(\"Response contains token\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property('token');\r",
                  "});\r",
                  "\r",
                  "// Test 3: Save token to environment for later use\r",
                  "var jsonData = pm.response.json();\r",
                  "pm.environment.set(\"auth_token\", jsonData.token);\r",
                  "pm.test(\"Token saved to environment\", function () {\r",
                  "    pm.expect(pm.environment.get(\"auth_token\")).to.not.be.empty;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "",
                "value": "",
                "type": "text",
                "disabled": true
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\" : \"admin\",\r\n    \"password\" : \"password123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://restful-booker.herokuapp.com/auth",
              "protocol": "https",
              "host": [
                "restful-booker",
                "herokuapp",
                "com"
              ],
              "path": [
                "auth"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Booking-CRUD",
      "item": [
        {
          "name": "TC03-Create-Valid-Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has bookingid\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property('bookingid');\r",
                  "    // Save booking ID for later tests\r",
                  "    pm.environment.set(\"booking_id\", jsonData.bookingid);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Firstname is correct\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.booking.firstname).to.equal(\"John\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is reasonable\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\": \"John\",\r\n    \"lastname\": \"Doe\",\r\n    \"totalprice\": 150,\r\n    \"depositpaid\": true,\r\n    \"bookingdates\": {\r\n      \"checkin\": \"2024-06-01\",\r\n      \"checkout\": \"2024-06-05\"\r\n    },\r\n    \"additionalneeds\": \"WiFi and breakfast\"\r\n  }",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
